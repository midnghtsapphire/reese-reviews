# ============================================================
# Reese Reviews — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ── Amazon Integration ───────────────────────────────────────
# Session cookie string copied from your browser's DevTools.
# Required only for live cookie-based import (mode=cookie).
# The app defaults to demo mode when this variable is absent.
# NEVER commit a real cookie value — treat it like a password.
#
# Example format (copy from browser DevTools → Application → Cookies → amazon.com):
# AMAZON_SESSION_COOKIE="session-id=123-4567890-1234567; ubid-main=123-456-789; ..."
AMAZON_SESSION_COOKIE=

# Amazon SP-API (Selling Partner API) credentials.
# Obtain from Seller Central → Apps & Services → Developer Tools → your app.
# These are entered via the UI (Business → Amazon → Connection tab) and stored
# in localStorage — do NOT hardcode real values here.
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
# Refresh token generated after authorizing your SP-API app.
AMAZON_LWA_REFRESH_TOKEN=
# Your seller account ID (e.g. A2EUQ1WTGCTBG2)
AMAZON_SELLER_ID=
# Marketplace ID — default is US (ATVPDKIKX0DER)
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Amazon affiliate tag appended to generated product links.
# Default: meetaudreyeva-20
# VITE_AFFILIATE_TAG=meetaudreyeva-20
