# ============================================================
# Reese Reviews — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ── Auth Fallback ────────────────────────────────────────────
# Simple password for legacy/fallback authentication.
# Used when Supabase Auth is unavailable or for quick access.
VITE_FALLBACK_PASSWORD=your-fallback-password

# ── OpenRouter (AI/LLM) ─────────────────────────────────────
VITE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ── Amazon Integration ───────────────────────────────────────
# Session cookie string copied from your browser's DevTools.
# Required only for live cookie-based import (mode=cookie).
# The app defaults to demo mode when this variable is absent.
# NEVER commit a real cookie value — treat it like a password.
AMAZON_SESSION_COOKIE=

# Amazon affiliate tag appended to generated product links.
# Default: meetaudreyeva-20
# VITE_AFFILIATE_TAG=meetaudreyeva-20

# ── Stripe (Payments) — uncomment when ready ─────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret

# ── Plaid (Banking) — uncomment when ready ───────────────────
# VITE_PLAID_CLIENT_ID=your-plaid-client-id
# PLAID_SECRET=your-plaid-secret

# ── HeyGen (Avatar Video) — uncomment when ready ─────────────
# HEYGEN_API_KEY=your-heygen-api-key
