# ============================================================
# Reese Reviews — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ── Auth Fallback ────────────────────────────────────────────
# Simple password for legacy/fallback authentication.
# Used when Supabase Auth is unavailable or for quick access.
VITE_FALLBACK_PASSWORD=your-fallback-password

# ── OpenRouter (AI/LLM) ─────────────────────────────────────
VITE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ── Amazon Integration ───────────────────────────────────────
# Session cookie string copied from your browser's DevTools.
# Required only for live cookie-based import (mode=cookie).
# The app defaults to demo mode when this variable is absent.
# NEVER commit a real cookie value — treat it like a password.
AMAZON_SESSION_COOKIE=

# Amazon affiliate tag appended to generated product links.
# Default: meetaudreyeva-20
# VITE_AFFILIATE_TAG=meetaudreyeva-20

# ── Backend API (Python / FastAPI) ───────────────────────────
# HashiCorp Vault — backend secrets are loaded from Vault at runtime.
# Only the Vault address and token go here. NEVER put API keys here.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# Database (optional — overrides Vault-loaded Supabase URL for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reese_reviews

# Telegram (optional — overrides Vault for local dev)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Secret token for Telegram webhook validation (set when registering webhook with setWebhook API)
# TELEGRAM_WEBHOOK_SECRET=

# Environment: development | production
ENVIRONMENT=development
# ── AI Review Video & Voice ──────────────────────────────────
# HeyGen: AI avatar video generation for review content
# Get your key at: https://app.heygen.com/settings/api
# Stored per-user in browser localStorage via Review Settings UI
# NOTE: Do NOT expose these in a public/shared environment
VITE_HEYGEN_API_KEY=

# ElevenLabs: AI voice synthesis for review voice-overs
# Get your key at: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=

# OpenAI: Review text generation, image captioning
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Picasso / DALL-E image generation (uses OpenAI key above)
# Set to "dall-e-3" or "dall-e-2" to choose model
# VITE_IMAGE_MODEL=dall-e-3
# ── Stripe (Payments) — uncomment when ready ─────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret
# ── Stripe Payment Links (create at https://dashboard.stripe.com/payment-links)
# VITE_STRIPE_LINK_PRO=https://buy.stripe.com/your-pro-link
# VITE_STRIPE_LINK_BUSINESS=https://buy.stripe.com/your-business-link

# ── Plaid (Banking) — uncomment when ready ───────────────────
# VITE_PLAID_CLIENT_ID=your-plaid-client-id
# PLAID_SECRET=your-plaid-secret

# ── HeyGen (Avatar Video) — uncomment when ready ─────────────
# HEYGEN_API_KEY=your-heygen-api-key
