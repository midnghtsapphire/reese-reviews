# ============================================================
# Reese Reviews — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ── Amazon Integration ───────────────────────────────────────
# Session cookie string copied from your browser's DevTools.
# Required only for live cookie-based import (mode=cookie).
# The app defaults to demo mode when this variable is absent.
# NEVER commit a real cookie value — treat it like a password.
#
# Example format (copy from browser DevTools → Application → Cookies → amazon.com):
# AMAZON_SESSION_COOKIE="session-id=123-4567890-1234567; ubid-main=123-456-789; ..."
AMAZON_SESSION_COOKIE=

# Amazon affiliate tag appended to generated product links.
# Default: meetaudreyeva-20
# VITE_AFFILIATE_TAG=meetaudreyeva-20

# ── Backend API (Python / FastAPI) ───────────────────────────
# HashiCorp Vault — backend secrets are loaded from Vault at runtime.
# Only the Vault address and token go here. NEVER put API keys here.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# Database (optional — overrides Vault-loaded Supabase URL for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reese_reviews

# Telegram (optional — overrides Vault for local dev)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Secret token for Telegram webhook validation (set when registering webhook with setWebhook API)
# TELEGRAM_WEBHOOK_SECRET=

# Environment: development | production
ENVIRONMENT=development
